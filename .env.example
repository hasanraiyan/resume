# Database
MONGODB_URI=mongodb://localhost:27017/your-database-name

# Encryption
ENCRYPTION_SECRET=your-encryption-secret-key-here
# STORED_ENCRYPTED_KEY=optional-stored-key-if-needed

# Base URL for social sharing
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# Admin Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password
ADMIN_EMAIL=your-admin-email@gmail.com

# Google OAuth (for Google login — only ADMIN_EMAIL is allowed)
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth Secret
NEXTAUTH_SECRET=your-nextauth-secret-key

# TOTP 2FA Secret (Base32 encoded)
# Generate with: node scripts/setup-totp-2fa.js
TOTP_SECRET=your-totp-secret


# Cloudinary for media uploads
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# UploadThing for additional storage
UPLOADTHING_SECRET=your-uploadthing-secret
UPLOADTHING_APP_ID=your-uploadthing-app-id

# App URL for chatbot utils
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron API Key for admin tasks
CRON_API_KEY=your-cron-api-key

# Attenda MCP API Key
# Used by external MCP clients (Claude Desktop, Cursor, etc.) to authenticate
# with the Attenda MCP server. Pass as Bearer token in Authorization header.
# OAuth 2.1 + PKCE (via /api/mcp-oauth) is also accepted — see src/lib/mcp/oauth.
# Generate: openssl rand -hex 32
ATTENDA_MCP_API_KEY=your-attenda-mcp-api-key

# Pocketly MCP API Key
# Same as above, but for the Pocketly MCP server.
# Generate: openssl rand -hex 32
POCKETLY_MCP_API_KEY=your-pocketly-mcp-api-key

# Coursify Unified Queue API Key
# Used for:
#   1. Cron worker: GET /api/cron/coursify-generate (triggered by cron-job.org)
#   2. External apps: POST /api/coursify/generate-topic/queue (pyqdeck, etc.)
# Generate: openssl rand -hex 32
COURSIFY_API_KEY=your-unified-coursify-api-key

# Pollinations AI — thumbnail generation for Coursify (https://enter.pollinations.ai)
POLLINATIONS_API_KEY=your-pollinations-api-key

# Tavily — internet search for Coursify AI Search Engine (https://tavily.com)
TAVILY_API_KEY=your-tavily-api-key

# Google Search — image search for agents (https://developers.google.com/custom-search/v1/overview)
GOOGLE_SEARCH_API_KEY=your-google-api-key
GOOGLE_SEARCH_CX=your-custom-search-engine-id

# YouTube Data API v3 — for Coursify video search (https://console.cloud.google.com/)
GOOGLE_API_KEY=your-youtube-api-key

# SearxNG — privacy-respecting meta-search engine (https://docs.searxng.org/)
SEARXNG_API_BASE=http://localhost:8080

# Database
MONGODB_URI=mongodb://localhost:27017/your-database-name

# Encryption
ENCRYPTION_SECRET=your-encryption-secret-key-here
# STORED_ENCRYPTED_KEY=optional-stored-key-if-needed

# Base URL for social sharing
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# Admin Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password

# NextAuth Secret
NEXTAUTH_SECRET=your-nextauth-secret-key


# Cloudinary for media uploads
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# UploadThing for additional storage
UPLOADTHING_SECRET=your-uploadthing-secret
UPLOADTHING_APP_ID=your-uploadthing-app-id

# App URL for chatbot utils
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron API Key for admin tasks
CRON_API_KEY=your-cron-api-key
